[user]
    email = morten@linderud.pw
    name = Morten Linderud
    signingkey = 9FECBE16
[commit]
    gpgSign = true
    verbose = true
[format]
    signOff = true
[color]
    ui = auto
[alias]
    s = status

    dt = difftool
    dc = diff --cached

    mt = mergetool

    aa = add --all
    ap = add -p

    b = branch -vv
    ba = branch -avv
    rem = remote -v

    ff = merge --ff-only
    pullff = pull --ff-only
    noff = merge --no-ff -v --stat
    fa = fetch --all

    c = commit -s
    amend = c --amend
    fixup = "!git c --fixup=$(git rev-parse HEAD)"

    autosquash = "!git rebase -i --autosquash"
    rr = "rebase --autosquash -i"
    rrs = "git rebase -S --autosquash -i"

    exec = "!f() { git rebase --exec \"$@\" ; }; f"

    recent = ! git branch -a --sort=-committerdate --format=\"%(committerdate:relative)%09%(refname:short)\" | head -10

    hd = show -p --pretty="tformat:"
    files = diff-tree --no-commit-id --name-only -r
    edit = "!vim $(git ls-files -m) -p"
    edit-commit = !vim `git diff-tree --no-commit-id --name-only -r  ${1-$(git rev-parse HEAD)}`

    jump = "!/usr/share/git/git-jump/git-jump"
    unstage = restore --staged --patch
    ignored = status --ignored

    fetch-pr = "!f() { \
        remote=${1:-origin}; \
        git fetch -p ${1:-origin} \"+refs/pull/*/head:refs/remotes/${remote}/pull/*\" \"+refs/merge-requests/*/head:refs/remotes/${remote}/merge-requests/*\"; \
        }; f"
    recent-pr = "for-each-ref --count=10 --no-merged=HEAD --sort=-committerdate --format='%(HEAD) %(align:35)%(color:yellow)%(refname:short)%(color:reset)%(end) - %(color:red)%(objectname:short)%(color:reset) - %(align:40)%(contents:subject)%(end) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))' '**/merge-requests/*' '**/pull/*'"
    pull-pr = "!f() { \
        if git rev-parse --verify remotes/${2:-origin}/pull/${1} &> /dev/null; then \
            git fetch ${2:-origin} pull/\"${1}\"/head:pr-\"${1}\"; \
        elif git rev-parse --verify remotes/${2:-origin}/merge-requests/${1} &> /dev/null; then \
            git fetch ${2:-origin} merge-requests/${1}/head:pr-${1}; \
        fi; \
        }; f"

[init]
    template = ~/.config/git/templates
    defaultBranch = master
[advice]
    detachedHead = false
[absorb]
    autoStageIfNothingStaged = true
    maxStack = 50
[core]
    hooksPath = ~/.config/git/hooks
    abbrev = 12
[branch]
    autoSetupMerge = inherit
    autoSetupRebase = always
    autoSetupRemote = true
    autoSetupMerge = inherit
[diff]
    tool = vimdiff
    renames = copies
    algorithm = histogram
[difftool]
    prompt = false
[difftool "vimdiff"]
    cmd = vim -d $BASE $LOCAL 
[merge]
    tool = vimdiff
    conflictStyle = diff3
    log = true
    keepbackup = false
[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
[mergetool]
    prompt = false
    keepBackup = false
[pretty]
    fixes = Fixes: %h (\"%s\")
[push]
    default = current
[pull]
    rebase = false
[rebase]
    autoStash = true
    updateRefs = true
[rerere]
    enabled = true
[sendemail]
    from = "Morten Linderud <morten@linderud.pw>"
    smtpserver = "/usr/bin/msmtp"
    annotate = true
    confirm = always
    envelopesender = auto
[includeIf "gitdir:~/jobb/"]
    path = ~/jobb/.gitconfig
[includeIf "gitdir:~/work/"]
    path = ~/work/.gitconfig
[includeIf "gitdir:~/.config/home.git"]
    path = ~/.config/git/config.home
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
